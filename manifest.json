{
  "manifest_version": 3,
  "name": "GitHub PR Quick Merge — Merge from List",
  "short_name": "PR Quick Merge",
  "version": "0.4.0",
  "description": "Squash, merge, or rebase pull requests directly from the GitHub Pull Requests list — no need to open each PR.",
  "author": "Brady Grapentine",
  "homepage_url": "https://github.com/bradygrapentine/gh-pr-quick-merge",
  "permissions": ["storage", "management", "alarms"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'none'"
  },
  "host_permissions": [
    "https://api.github.com/*",
    "https://github.com/login/device/code",
    "https://github.com/login/oauth/access_token"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PR Quick Merge"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/pulls*",
        "https://github.com/*/pulls*",
        "https://github.com/issues*"
      ],
      "js": [
        "lib/pr-helpers.js",
        "lib/templates.js",
        "lib/shortcuts.js",
        "lib/stale-pr.js",
        "lib/api.js",
        "lib/update-branch.js",
        "lib/auto-rebase.js",
        "lib/merge-queue.js",
        "lib/bulk-ops.js",
        "lib/list-mode.js",
        "lib/qm-brand.js",
        "lib/qm-theme.js",
        "lib/qm-visual-prefs.js",
        "lib/qm-toast.js",
        "lib/qm-row-widget.js",
        "content.js"
      ],
      "css": ["theme.css", "styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "gh-pr-quick-merge@grapentineb.dev",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
