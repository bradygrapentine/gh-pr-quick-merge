{
  "manifest_version": 3,
  "name": "GitHub PR Quick Merge — Merge from List",
  "short_name": "PR Quick Merge",
  "version": "0.2.0",
  "version_name": "0.2.0-rc.1 (dev)",
  "description": "Squash, merge, or rebase pull requests directly from the GitHub Pull Requests list — no need to open each PR.",
  "permissions": ["storage", "management"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'none'"
  },
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PR Quick Merge"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/pulls*",
        "https://github.com/*/pulls*",
        "https://github.com/issues*"
      ],
      "js": ["lib/pr-helpers.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "gh-pr-quick-merge@grapentineb.dev",
      "strict_min_version": "115.0"
    }
  }
}
