{
  "name": "gh-pr-quick-merge",
  "private": true,
  "version": "1.1.0",
  "description": "Squash, merge, or rebase pull requests directly from the GitHub Pull Requests list — no need to open each PR.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --project=e2e",
    "test:e2e:visual": "playwright test --project=visual",
    "test:perf": "playwright test --project=perf",
    "vendor:sentry": "bash scripts/vendor-sentry.sh",
    "package": "bash scripts/package.sh",
    "release": "bash scripts/release.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "happy-dom": "^20.9.0",
    "vitest": "latest"
  }
}
